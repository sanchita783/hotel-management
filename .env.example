# ─────────────────────────────────────────────
# Hotel Management System - Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Database
DB_URL=jdbc:mysql://localhost:3306/hotel_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# JWT (min 64 chars, use: openssl rand -hex 32)
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970

# Email (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# Application
APP_NAME=Grand Hotel Management System
FRONTEND_URL=http://localhost:3000
SUPPORT_EMAIL=support@grandhotel.com

# Default Admin (change after first login!)
ADMIN_EMAIL=admin@grandhotel.com
ADMIN_PASSWORD=Admin@1234

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
